#!/bin/bash
#
# schupfn - run toolbox containers in VMs via virtme-ng
#
# SPDX-License-Identifier: Apache-2.0

PROGNAME="schupfn"
VERSION="0.1.0"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/schupfn/roots"
if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
    SESSION_DIR="$XDG_RUNTIME_DIR/schupfn/sessions"
else
    SESSION_DIR=""
fi
META_FILE=".schupfn-meta"

# ── Colors ───────────────────────────────────────────────────────────────────

if [ -t 2 ]; then
    C_RED=$'\033[1;31m'
    C_YELLOW=$'\033[1;33m'
    C_RESET=$'\033[0m'
else
    C_RED=""
    C_YELLOW=""
    C_RESET=""
fi

if [ -t 1 ]; then
    C_CYAN=$'\033[0;36m'
    C_BOLD=$'\033[1m'
    C_RESET_OUT=$'\033[0m'
else
    C_CYAN=""
    C_BOLD=""
    C_RESET_OUT=""
fi

# ── Helpers ──────────────────────────────────────────────────────────────────

die() {
    echo "${C_RED}error:${C_RESET} $*" >&2
    exit 1
}

warn() {
    echo "${C_YELLOW}warning:${C_RESET} $*" >&2
}

info() {
    echo "${C_CYAN}::${C_RESET_OUT} $*"
}

check_command() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' is not installed or not in PATH"
}

check_prerequisites() {
    check_command podman
    check_command vng
    check_command ssh
}

# Validate that a container name is safe for use in path construction.
# Rejects names containing path separators or traversal sequences.
validate_container_name() {
    local name="$1"
    case "$name" in
        */*|*..*)
            die "invalid container name '$name': must not contain '/' or '..'"
            ;;
        .*)
            die "invalid container name '$name': must not start with '.'"
            ;;
    esac
}

# Classify a single export path as a directory or file.
# Directories are appended to rw_mount_dirs or ro_mount_dirs (depending
# on mode). Files are appended to dotfiles. Symlinks that point to a
# directory also produce a rootfs_symlinks entry.
#
# These arrays must exist in the caller's scope:
#   rw_mount_dirs, ro_mount_dirs, rootfs_symlinks, dotfiles
#
# $1 = path, $2 = "rw" or "ro"
classify_export() {
    local path="$1"
    local mode="$2"
    # Expand ~ in case the shell didn't (e.g. quoted argument)
    path="${path/#\~\//$HOME/}"
    if [ ! -e "$path" ]; then
        die "export path does not exist: $path"
    fi

    if [ -d "$path" ]; then
        local resolved
        resolved="$(realpath "$path")"
        if [ "$mode" = "rw" ]; then
            rw_mount_dirs+=("$resolved")
        else
            ro_mount_dirs+=("$resolved")
        fi

        # If the path was a symlink, remember to recreate it in the rootfs
        local abs_dir
        abs_dir="$(cd "$path" && pwd -L)"
        if [ "$abs_dir" != "$resolved" ]; then
            rootfs_symlinks+=("$abs_dir:$resolved")
        fi
    else
        # Regular file (or symlink to a file): use the absolute path of
        # the link itself (not its target) so the file is placed at the
        # original path inside the VM.  tar -h dereferences the symlink
        # at copy time.
        local abs_file
        abs_file="$(cd "$(dirname "$path")" && echo "$PWD/$(basename "$path")")"
        dotfiles+=("$abs_file")
    fi
}

# Add a directory's top-level component to the overlay list if not
# already present. The overlay_dirs array must exist in the caller's scope.
add_overlay() {
    local top_dir
    top_dir=$(echo "$1" | cut -d/ -f2)
    top_dir="/$top_dir"
    local found=0
    for d in "${overlay_dirs[@]}"; do
        if [ "$d" = "$top_dir" ]; then
            found=1
            break
        fi
    done
    if [ "$found" = "0" ]; then
        overlay_dirs+=("$top_dir")
    fi
}

# Check for nested export conflicts between rw_mount_dirs and
# ro_mount_dirs. A 9p mount on a parent directory shadows any child
# mount, so --export-ro /foo --export-rw /foo/bar cannot work: the ro
# mount on /foo makes everything beneath it read-only regardless of the
# child --rwdir.
#
# These arrays must exist in the caller's scope:
#   rw_mount_dirs, ro_mount_dirs
check_nested_export_conflicts() {
    local rw ro
    for rw in "${rw_mount_dirs[@]}"; do
        for ro in "${ro_mount_dirs[@]}"; do
            # Exact same path exported as both ro and rw
            if [[ "$rw" = "$ro" ]]; then
                die "conflicting exports: '$rw' is exported as both" \
                    "ro and rw. Remove one of the duplicate exports."
            fi

            # Build a prefix that works for root "/" without producing
            # a double-slash ("//child" would never match "/child").
            local ro_prefix="$ro"
            [[ "$ro_prefix" != "/" ]] && ro_prefix+="/"
            local rw_prefix="$rw"
            [[ "$rw_prefix" != "/" ]] && rw_prefix+="/"

            # rw dir is a child of an ro dir
            if [[ "$rw" = "$ro_prefix"* ]]; then
                die "conflicting exports: '$rw' (rw) is nested inside" \
                    "'$ro' (ro). The read-only mount on the parent" \
                    "shadows the child. Remove one or export the parent" \
                    "as rw."
            fi
            # ro dir is a child of an rw dir
            if [[ "$ro" = "$rw_prefix"* ]]; then
                die "conflicting exports: '$ro' (ro) is nested inside" \
                    "'$rw' (rw). The read-write mount on the parent" \
                    "shadows the child. Remove one or export the parent" \
                    "as ro."
            fi
        done
    done
}

# Verify the container has the packages schupfn needs and offer to
# install any that are missing.
check_container_prerequisites() {
    local name="$1"
    local -a missing=()

    # Mount the container, check all binaries, unmount — in a single
    # podman unshare call.  Each podman unshare creates a user namespace
    # so batching saves significant overhead (5 calls → 1).
    local check_result
    check_result=$(podman unshare bash -c '
        mnt=$(podman mount "$1" 2>/dev/null) || exit 1
        test -x "$mnt/usr/sbin/sshd" || echo openssh-server
        test -x "$mnt/usr/lib/systemd/systemd-udevd" || \
            test -x "$mnt/lib/systemd/systemd-udevd" || echo systemd-udev
        test -x "$mnt/usr/bin/busybox" || \
            test -x "$mnt/bin/busybox" || echo busybox
        podman unmount "$1" >/dev/null 2>&1
    ' _ "$name" 2>/dev/null) || die "failed to mount container '$name' for prerequisite check"

    while IFS= read -r pkg; do
        [ -n "$pkg" ] && missing+=("$pkg")
    done <<< "$check_result"

    if [ ${#missing[@]} -eq 0 ]; then
        return
    fi

    warn "container '$name' is missing required packages: ${missing[*]}"
    printf "Install them now? [y/N] "
    read -r answer
    case "$answer" in
        y|Y|yes|YES)
            info "installing ${missing[*]} in container '$name'..."
            if ! toolbox run -c "$name" sudo dnf install -y "${missing[@]}"; then
                die "failed to install packages"
            fi
            info "packages installed"
            ;;
        *)
            die "cannot continue without: ${missing[*]}"
            ;;
    esac
}

# ── SSH / VM lifecycle ──────────────────────────────────────────────────────

# Find a free port for SSH (VSOCK CID or TCP port, depending on vng's choice).
# We pick a random port in the ephemeral range and verify it's not in use.
find_free_port() {
    local port
    for _ in $(seq 1 20); do
        port=$((RANDOM % 16384 + 49152))
        # Check that nothing is listening on this port (covers TCP case)
        if ! ss -tln "sport = :$port" 2>/dev/null | grep -q "$port"; then
            echo "$port"
            return 0
        fi
    done
    die "failed to find a free port for SSH"
}

# Wait until SSH inside the VM is reachable, then return.
# Uses vng --ssh-client with a short-lived test command.
wait_for_ssh() {
    local port="$1"
    local timeout="${2:-60}"
    local elapsed=0

    info "waiting for VM to boot..."

    while [ "$elapsed" -lt "$timeout" ]; do
        # Check that the background VM process is still alive
        if [ -n "${VNG_PID:-}" ] && ! kill -0 "$VNG_PID" 2>/dev/null; then
            die "VM process exited before SSH became available"
        fi

        if vng --ssh-client "$port" --ssh-tcp --remote-cmd "true" >/dev/null 2>&1; then
            return 0
        fi

        sleep 1
        elapsed=$((elapsed + 1))
    done

    die "timed out waiting for SSH (${timeout}s). VM may have failed to boot."
}

# Collect all PIDs in the process tree rooted at $1 (depth-first).
_pstree_pids() {
    local pid="$1"
    local children
    children=$(ps -o pid= --ppid "$pid" 2>/dev/null) || true
    for child in $children; do
        _pstree_pids "$child"
    done
    echo "$pid"
}

# Clean up the background VM process. Called via trap on EXIT.
# vng spawns a shell which spawns qemu, so we must kill the entire
# process tree — not just the top-level PID — to avoid orphaned
# qemu instances.
cleanup_vm() {
    if [ -n "${VNG_PID:-}" ] && kill -0 "$VNG_PID" 2>/dev/null; then
        info "shutting down VM (pid $VNG_PID)..."
        # Collect the full process tree (children before parents)
        local -a pids
        mapfile -t pids < <(_pstree_pids "$VNG_PID")

        # Graceful SIGTERM to the whole tree
        for pid in "${pids[@]}"; do
            kill "$pid" 2>/dev/null
        done

        # Give them a moment to shut down
        local i=0
        while kill -0 "$VNG_PID" 2>/dev/null && [ "$i" -lt 5 ]; do
            sleep 1
            i=$((i + 1))
        done

        # Force kill any survivors
        if kill -0 "$VNG_PID" 2>/dev/null; then
            mapfile -t pids < <(_pstree_pids "$VNG_PID")
            for pid in "${pids[@]}"; do
                kill -9 "$pid" 2>/dev/null
            done
        fi
        wait "$VNG_PID" 2>/dev/null
    fi

    # Remove session file after shutdown so the VM remains discoverable
    # by 'join'/'list' if the kill above fails for any reason.
    if [ -n "${SESSION_NAME:-}" ] && [ -n "${VNG_PID:-}" ]; then
        remove_session "$SESSION_NAME" "$VNG_PID"
    fi
}

# ── Session management ──────────────────────────────────────────────────────

# Write a session file for a running VM so other processes can join it.
# Session files live in $SESSION_DIR and are named <name>-<pid>.session.
# No-op when SESSION_DIR is empty (XDG_RUNTIME_DIR unset).
write_session() {
    if [ -z "$SESSION_DIR" ]; then
        warn "XDG_RUNTIME_DIR is not set; session tracking disabled ('join' will not work)"
        return 0
    fi

    local name="$1"
    local pid="$2"
    local ssh_port="$3"
    local workdir="$4"
    local ssh_key="${5:-}"

    mkdir -p -m 0700 "$SESSION_DIR"

    cat > "$SESSION_DIR/${name}-${pid}.session" <<EOF
name=$name
pid=$pid
ssh_port=$ssh_port
workdir=$workdir
ssh_key=$ssh_key
started_at=$(date -Iseconds)
EOF
}

# Remove the session file for a VM. No-op when SESSION_DIR is empty.
remove_session() {
    [ -n "$SESSION_DIR" ] || return 0
    local name="$1"
    local pid="$2"
    rm -f "$SESSION_DIR/${name}-${pid}.session"
}

# Read a key from a session file. Returns empty string if missing.
read_session() {
    local session_file="$1"
    local key="$2"

    while IFS='=' read -r k v; do
        if [ "$k" = "$key" ]; then
            echo "$v"
            return 0
        fi
    done < "$session_file"
    return 0
}

# Remove session files whose PIDs are no longer running or whose pid
# field is missing/invalid (treat as corrupt).
cleanup_stale_sessions() {
    [ -d "$SESSION_DIR" ] || return 0

    for session_file in "$SESSION_DIR"/*.session; do
        [ -f "$session_file" ] || continue
        local pid
        pid=$(read_session "$session_file" "pid")
        if [ -z "$pid" ] || ! [[ "$pid" =~ ^[0-9]+$ ]]; then
            # Missing or non-numeric pid — corrupt session file
            rm -f "$session_file"
        elif ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$session_file"
        fi
    done
}

# List active session files, optionally filtered by container name.
# Prints one session file path per line.
# Stale sessions are cleaned up first.
list_active_sessions() {
    local filter_name="${1:-}"

    cleanup_stale_sessions
    [ -d "$SESSION_DIR" ] || return 0

    for session_file in "$SESSION_DIR"/*.session; do
        [ -f "$session_file" ] || continue
        if [ -n "$filter_name" ]; then
            local name
            name=$(read_session "$session_file" "name")
            if [ "$name" != "$filter_name" ]; then
                continue
            fi
        fi
        echo "$session_file"
    done
}

# ── Configuration file ───────────────────────────────────────────────────────

# Walk from the given directory up to / looking for .schupfn/config.yml.
# If none is found, fall back to XDG_CONFIG_HOME/schupfn/ — first trying
# <container>-config.yml (when a container name is given), then
# default-config.yml.  XDG_CONFIG_HOME defaults to ~/.config.
# Prints the path of the first config found, or nothing if none exists.
#
# Usage: find_config_file <start-dir> [container-name]
find_config_file() {
    local dir="$1"
    local container="${2:-}"
    local physical_dir
    physical_dir="$(realpath "$dir" 2>/dev/null)" || physical_dir="$dir"

    # Walk upward from the logical path first, then (if it differs)
    # from the physical path, so configs next to the real directory
    # are found even when $PWD is a symlink.
    local -a roots=("$dir")
    if [ "$physical_dir" != "$dir" ]; then
        roots+=("$physical_dir")
    fi

    local root
    for root in "${roots[@]}"; do
        local d="$root"
        while true; do
            local candidate="$d/.schupfn/config.yml"
            if [ -f "$candidate" ]; then
                realpath "$candidate"
                return 0
            fi
            if [ "$d" = "/" ]; then
                break
            fi
            d="${d%/*}"
            [ -z "$d" ] && d="/"
        done
    done

    # Fall back to user-level config under XDG_CONFIG_HOME
    local xdg_dir="${XDG_CONFIG_HOME:-$HOME/.config}/schupfn"

    # Try container-specific config first
    if [ -n "$container" ]; then
        local xdg_container="$xdg_dir/${container}-config.yml"
        if [ -f "$xdg_container" ]; then
            echo "$xdg_container"
            return 0
        fi
    fi

    # Then try the default config
    local xdg_default="$xdg_dir/default-config.yml"
    if [ -f "$xdg_default" ]; then
        echo "$xdg_default"
        return 0
    fi

    return 1
}

# Parse a config file with yq and set the corresponding variables.
# Sets the following variables in the caller's scope via nameref:
#   _cfg_container - default container name, empty if not set
#   _cfg_command   - command to run instead of a shell, empty if not set
#   _cfg_exports   - array of read-only export paths from config
#   _cfg_exports_rw - array of read-write export paths from config
#   _cfg_memory    - VM memory (e.g. "2G"), empty if not set
#   _cfg_cpus      - VM CPU count, empty if not set
#   _cfg_network   - "0" if network: false, empty if not set
#   _cfg_ssh_key   - path to SSH key, empty if not set
load_config() {
    local config_file="$1"

    check_command yq

    # Extract everything in a single yq invocation.  The output is a
    # stream of sentinel-delimited sections that we parse in pure bash.
    #
    #   __SCALARS__
    #   container=<value>
    #   command=<value>
    #   memory=<value>
    #   cpus=<value>
    #   network=<value>
    #   ssh_key=<value>
    #   __EXPORT_RO__
    #   <path>          (one per line)
    #   __EXPORT_RW__
    #   <path>          (one per line)
    #   __KEYS__
    #   <dotted.key>    (one per line)
    #
    local blob
    blob=$(yq -r '
        "__SCALARS__",
        "container=" + (.container // ""),
        "command="   + (.command // ""),
        "memory="    + (.vm.memory // ""),
        "cpus="      + ((.vm.cpus // "") | tostring),
        "network="   + (.vm.network | tostring),
        "ssh_key="   + (.ssh_key // ""),
        "__EXPORT_RO__",
        (.["export-ro"] // [] | .[]),
        "__EXPORT_RW__",
        (.["export-rw"] // [] | .[]),
        "__KEYS__",
        ([.. | path | map(select(tag != "!!int")) | join(".")] | unique | .[])
    ' "$config_file" 2>/dev/null) || die "failed to parse config file: $config_file"

    # Parse the blob line by line — zero additional forks.
    local section="" line
    local raw_cpus="" raw_network="" raw_key=""
    while IFS= read -r line; do
        case "$line" in
            __SCALARS__|__EXPORT_RO__|__EXPORT_RW__|__KEYS__)
                section="$line"; continue ;;
        esac

        case "$section" in
            __SCALARS__)
                local key="${line%%=*}"
                local val="${line#*=}"
                case "$key" in
                    container) _cfg_container="$val" ;;
                    command)   _cfg_command="$val" ;;
                    memory)    _cfg_memory="$val" ;;
                    cpus)      raw_cpus="$val" ;;
                    network)   raw_network="$val" ;;
                    ssh_key)   raw_key="$val" ;;
                esac
                ;;
            __EXPORT_RO__)
                if [ -n "$line" ]; then
                    [[ "$line" != /* && "$line" != ~* ]] && line="$HOME/$line"
                    _cfg_exports+=("$line")
                fi
                ;;
            __EXPORT_RW__)
                if [ -n "$line" ]; then
                    [[ "$line" != /* && "$line" != ~* ]] && line="$HOME/$line"
                    _cfg_exports_rw+=("$line")
                fi
                ;;
            __KEYS__)
                [ -z "$line" ] && continue
                local _known_keys=" container command export-ro export-rw vm vm.memory vm.cpus vm.network ssh_key "
                if [[ "$_known_keys" != *" $line "* ]]; then
                    warn "unknown config key '$line' in $config_file"
                fi
                ;;
        esac
    done <<< "$blob"

    if [ -n "$raw_cpus" ]; then
        _cfg_cpus="$raw_cpus"
    fi
    if [ "$raw_network" = "false" ]; then
        _cfg_network="0"
    fi
    if [ -n "$raw_key" ]; then
        raw_key="${raw_key/#\~\//$HOME/}"
        if [ ! -f "$raw_key" ]; then
            die "ssh_key not found: $raw_key (from $config_file)"
        fi
        _cfg_ssh_key="$raw_key"
    fi
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
Usage: $PROGNAME <command> [options]

Run toolbox containers in VMs via virtme-ng.

Commands:
  enter <name>    Export a toolbox container and enter it as a VM
  join [<name>]   Open a new SSH session to a running VM
  list            Show cached rootfs entries and their freshness status
  clean [<name>]  Remove cached rootfs entries

Run '$PROGNAME <command> --help' for more information on a command.
EOF
}

usage_enter() {
    cat <<EOF
Usage: $PROGNAME enter [<name>] [options]

Export the toolbox container <name> to a local rootfs and boot it as a VM
using virtme-ng. The VM is started in the background and connected to via
SSH. The current directory is mounted read-write inside the VM.

If <name> is omitted, the 'container' field from the config file is used.

The container must have these packages installed:
  openssh-server, systemd-udev, busybox

Requires SSH public keys in ~/.ssh/id_*.pub for authentication.

Options:
  --export-ro <path>  Additional host path to make available in the VM (repeatable)
                      Directories are mounted read-only at their original path.
                      Files are copied into the VM at their original path.
  --export-rw <path>  Like --export-ro, but directories are mounted read-write
  --refresh         Force re-export of the rootfs even if it appears fresh
  --deep-check      Use 'podman diff' for thorough staleness detection
  --memory <size>   VM memory, e.g. 4G, 512M (default: 4G)
  --cpus <n>        VM CPU count (default: host CPU count)
  --command <cmd>   Run <cmd> in the VM instead of an interactive shell
  --config <path>   Use <path> as config file instead of searching for one
  --no-network      Disable the extra network device (SSH network device remains)
  --verbose         Show VM boot output
  -h, --help        Show this help

Configuration file:
  schupfn searches from \$PWD upward for .schupfn/config.yml. The first
  file found is loaded. Use --config to specify an explicit path instead.
  CLI arguments override config values; for --export-ro and --export-rw
  the config and CLI lists are merged.

  Example .schupfn/config.yml:
    container: my-toolbox
    command: make test
    export-ro:
      - ~/src/shared-lib
      - ~/.zshrc
    export-rw:
      - ~/src/work-in-progress
    vm:
      memory: 8G
      cpus: 4
      network: false
    ssh_key: ~/.ssh/id_ed25519
EOF
}

usage_join() {
    cat <<EOF
Usage: $PROGNAME join [<name>] [options]

Open a new SSH session to an already-running VM.

If <name> is omitted and exactly one VM is running, that VM is joined
automatically. If multiple VMs are running, an interactive menu is shown.

Options:
  --command <cmd>   Run <cmd> in the VM instead of an interactive shell
  -h, --help        Show this help
EOF
}

# ── Metadata / Cache ────────────────────────────────────────────────────────

# Write metadata file after a successful export
write_meta() {
    local rootfs_dir="$1"
    local image_id="$2"
    local container_id="$3"
    local inspect_hash="$4"

    cat > "$rootfs_dir/$META_FILE" <<EOF
image_id=$image_id
container_id=$container_id
inspect_hash=$inspect_hash
exported_at=$(date -Iseconds)
EOF
}

# Read a key from the metadata file. Returns empty string if missing.
read_meta() {
    local rootfs_dir="$1"
    local key="$2"
    local meta_path="$rootfs_dir/$META_FILE"

    if [ ! -f "$meta_path" ]; then
        return 0
    fi

    # shellcheck disable=SC2034
    while IFS='=' read -r k v; do
        if [ "$k" = "$key" ]; then
            echo "$v"
            return 0
        fi
    done < "$meta_path"
    return 0
}

# Gather current container state and return as key=value lines.
# Merges two podman inspect --format calls into one (3 → 2 total).
gather_container_state() {
    local name="$1"

    # One podman inspect: --format gives us both IDs on separate lines.
    local ids
    ids=$(podman inspect --format '{{.Image}}{{"\n"}}{{.Id}}' "$name" 2>/dev/null) \
        || die "failed to inspect container '$name'"

    local image_id container_id
    { read -r image_id; read -r container_id; } <<< "$ids"

    if [ -z "$image_id" ]; then
        die "failed to get image ID for container '$name'"
    fi
    if [ -z "$container_id" ]; then
        die "failed to get container ID for '$name'"
    fi

    # Hash the full JSON for change detection.  This is a second
    # podman inspect, but the alternative (parsing JSON in bash) is
    # worse.  The original code used three separate calls and checked
    # $? of cut (always 0) instead of podman inspect.
    local inspect_hash_raw
    inspect_hash_raw=$(podman inspect "$name" 2>/dev/null | sha256sum)
    local inspect_hash="${inspect_hash_raw%%[[:space:]]*}"

    if [ -z "$inspect_hash" ]; then
        die "failed to compute inspect hash for '$name'"
    fi

    echo "image_id=$image_id"
    echo "container_id=$container_id"
    echo "inspect_hash=$inspect_hash"
}

# Check whether the cached rootfs is fresh.
# Returns 0 if fresh, 1 if stale or missing.
check_freshness() {
    local name="$1"
    local rootfs_dir="$2"
    local deep_check="$3"

    if [ ! -d "$rootfs_dir" ] || [ ! -f "$rootfs_dir/$META_FILE" ]; then
        info "no cached rootfs found for '$name'"
        return 1
    fi

    local stored_image_id stored_container_id stored_inspect_hash
    stored_image_id=$(read_meta "$rootfs_dir" "image_id")
    stored_container_id=$(read_meta "$rootfs_dir" "container_id")
    stored_inspect_hash=$(read_meta "$rootfs_dir" "inspect_hash")

    # Gather current state
    local current_state
    current_state=$(gather_container_state "$name")

    local current_image_id="" current_container_id="" current_inspect_hash=""
    while IFS='=' read -r k v; do
        case "$k" in
            image_id)       current_image_id="$v" ;;
            container_id)   current_container_id="$v" ;;
            inspect_hash)   current_inspect_hash="$v" ;;
        esac
    done <<< "$current_state"

    if [ "$stored_image_id" != "$current_image_id" ]; then
        info "image ID changed for '$name'"
        return 1
    fi

    if [ "$stored_container_id" != "$current_container_id" ]; then
        info "container ID changed for '$name'"
        return 1
    fi

    if [ "$stored_inspect_hash" != "$current_inspect_hash" ]; then
        info "container configuration changed for '$name'"
        return 1
    fi

    if [ "$deep_check" = "1" ]; then
        info "running deep check (podman diff) for '$name'..."
        local diff_hash_raw
        diff_hash_raw=$(podman diff "$name" 2>/dev/null | sha256sum)
        local diff_hash="${diff_hash_raw%%[[:space:]]*}"
        if [ -z "$diff_hash" ]; then
            warn "podman diff failed, treating rootfs as stale"
            return 1
        fi

        local stored_diff_hash
        stored_diff_hash=$(read_meta "$rootfs_dir" "diff_hash")

        if [ "$stored_diff_hash" != "$diff_hash" ]; then
            info "filesystem changes detected in '$name'"
            return 1
        fi
    fi

    return 0
}

# ── Kernel modules ──────────────────────────────────────────────────────────

# Copy the host's kernel modules for virtio_net into the exported rootfs.
# The VM boots the host kernel, but the initramfs only includes modules
# for 9p/virtiofs. virtio_net (needed for networking) must be available
# in the rootfs so udevd can load it during coldplug.
install_vm_modules() {
    local rootfs_dir="$1"
    local kver
    kver=$(uname -r)
    local host_moddir="/lib/modules/$kver"
    local rootfs_moddir="$rootfs_dir/usr/lib/modules/$kver"

    if [ ! -d "$host_moddir" ]; then
        warn "host kernel modules not found at $host_moddir — networking may not work"
        return
    fi

    # Skip if we've already installed modules (check for our marker file)
    if [ -f "$rootfs_moddir/.schupfn-modules" ]; then
        return
    fi

    info "installing kernel modules ($kver) into rootfs"

    # Copy virtio_net and its dependencies. Collect all source→dest
    # pairs first, then do a single podman unshare call to copy them
    # all (each podman unshare creates a user namespace, so batching
    # saves significant overhead).
    local -a mod_pairs=()
    while IFS= read -r line; do
        local mod_path="${line#insmod }"
        mod_path="${mod_path%%[[:space:]]*}"
        if [ -f "$mod_path" ]; then
            local rel_path="${mod_path#/lib/modules/$kver/}"
            mod_pairs+=("$mod_path" "$rootfs_moddir/$rel_path")
        fi
    done < <(modprobe --show-depends virtio_net 2>/dev/null)

    # Single podman unshare: create directories, copy modules, leave marker.
    podman unshare bash -c '
        rootfs_moddir="$1"; shift
        while [ $# -ge 2 ]; do
            mkdir -p "${2%/*}"
            cp "$1" "$2"
            shift 2
        done
        touch "$rootfs_moddir/.schupfn-modules"
    ' _ "$rootfs_moddir" "${mod_pairs[@]}"

    # Generate modules.dep so modprobe can resolve dependencies
    depmod -a -b "$rootfs_dir" "$kver" 2>/dev/null
}

# ── Export ───────────────────────────────────────────────────────────────────

# Ensure the current user exists in the rootfs's /etc/passwd and /etc/group.
# Toolbox containers create the user at runtime, but podman export captures
# a static snapshot that typically only has system users.
prepare_rootfs_user() {
    local rootfs_dir="$1"
    local username
    username=$(whoami)

    local uid gid homedir shell
    uid=$(id -u)
    gid=$(id -g)
    homedir="$HOME"
    shell=$(getent passwd "$username" | cut -d: -f7)
    shell="${shell:-/bin/bash}"

    local groupname
    groupname=$(id -gn)

    local passwd_file="$rootfs_dir/etc/passwd"
    local group_file="$rootfs_dir/etc/group"

    # Add group if not present
    if ! grep -q "^${groupname}:" "$group_file" 2>/dev/null; then
        info "adding group '$groupname' (gid $gid) to rootfs"
        echo "${groupname}:x:${gid}:" >> "$group_file"
    fi

    # Use /bin/bash if the user's shell doesn't exist in the rootfs
    if [ ! -x "$rootfs_dir$shell" ]; then
        shell=/bin/bash
    fi

    # Add user if not present
    if ! grep -q "^${username}:" "$passwd_file" 2>/dev/null; then
        info "adding user '$username' (uid $uid) to rootfs"
        echo "${username}:x:${uid}:${gid}::${homedir}:${shell}" >> "$passwd_file"
    fi

    # Ensure home directory exists
    mkdir -p "$rootfs_dir$homedir"
}

# Wrap sshd so it fixes the privsep directory ownership before starting.
# On a 9p rootfs all files appear as the host user's UID, but sshd
# requires /usr/share/empty.sshd to be owned by root. The wrapper
# bind-mounts a tmpfs over it (which IS root-owned) before exec'ing
# the real sshd binary.
fix_sshd_privsep() {
    local rootfs_dir="$1"
    local sshd_path="$rootfs_dir/usr/sbin/sshd"
    local sshd_real="$rootfs_dir/usr/sbin/sshd.real"

    # Skip if already wrapped
    if [ -f "$sshd_real" ]; then
        return
    fi

    if [ ! -f "$sshd_path" ]; then
        return
    fi

    # Rename the real sshd and install a wrapper.
    # Need podman unshare because /usr/sbin is dr-xr-xr-x.
    podman unshare mv "$sshd_path" "$sshd_real"
    podman unshare bash -c 'cat > "$1"' _ "$sshd_path" <<'WRAPPER'
#!/bin/bash
# schupfn: sshd wrapper to fix privsep directory ownership on 9p rootfs
privsep_dir=/usr/share/empty.sshd
if [ -d "$privsep_dir" ]; then
    mount -t tmpfs -o size=4k,mode=0755 tmpfs "$privsep_dir" 2>/dev/null
fi
exec /usr/sbin/sshd.real "$@"
WRAPPER
    podman unshare chmod +x "$sshd_path"
}

export_rootfs() {
    local name="$1"
    local rootfs_dir="$2"

    info "exporting container '$name' to $rootfs_dir ..."

    # Remove old rootfs if it exists. Use podman unshare to get root
    # in the user namespace — the exported rootfs contains directories
    # without write permission (e.g. /usr/lib64 is dr-xr-xr-x) that
    # a regular rm cannot remove.
    if [ -d "$rootfs_dir" ]; then
        podman unshare rm -rf "$rootfs_dir"
        if [ $? -ne 0 ]; then
            die "failed to remove old rootfs at '$rootfs_dir'"
        fi
    fi

    # Use restrictive permissions so other users cannot read the rootfs
    # contents (container filesystem, passwd/group entries, config, etc.)
    mkdir -p -m 0700 "$rootfs_dir"
    if [ $? -ne 0 ]; then
        die "failed to create directory '$rootfs_dir'"
    fi

    podman export "$name" | tar -xf - -C "$rootfs_dir"
    local -a pipe_rc=("${PIPESTATUS[@]}")
    if [ "${pipe_rc[0]}" -ne 0 ] || [ "${pipe_rc[1]}" -ne 0 ]; then
        podman unshare rm -rf "$rootfs_dir"
        die "failed to export container '$name'"
    fi

    # Ensure the current user exists in the rootfs. Toolbox containers
    # normally create the user at start time, but a podman-exported rootfs
    # is a static snapshot that may not have it.
    prepare_rootfs_user "$rootfs_dir"

    # Copy the host's kernel modules for virtio_net into the rootfs.
    # The container has udevd (checked by check_container_prerequisites)
    # which will load these modules during coldplug.
    install_vm_modules "$rootfs_dir"

    # Fix sshd privilege separation directory. The rootfs is served via
    # 9p with security_model=none, so all files appear as the host user's
    # UID inside the VM. sshd requires its privsep directory to be owned
    # by root. We wrap sshd with a script that bind-mounts a tmpfs (which
    # IS owned by root) over the privsep directory before starting sshd.
    fix_sshd_privsep "$rootfs_dir"

    # Gather state and write metadata
    local state
    state=$(gather_container_state "$name")

    local image_id="" container_id="" inspect_hash=""
    while IFS='=' read -r k v; do
        case "$k" in
            image_id)       image_id="$v" ;;
            container_id)   container_id="$v" ;;
            inspect_hash)   inspect_hash="$v" ;;
        esac
    done <<< "$state"

    write_meta "$rootfs_dir" "$image_id" "$container_id" "$inspect_hash"

    info "export complete"
}

# ── Subcommand: enter ───────────────────────────────────────────────────────

cmd_enter() {
    local name=""
    local refresh=0
    local deep_check=0
    local memory=""
    local cpus=""
    local network=""
    local verbose=0
    local ssh_key=""
    local command=""
    local cli_config=""
    local -a exports=()
    local -a exports_rw=()
    local cli_memory="" cli_cpus="" cli_network=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage_enter
                exit 0
                ;;
            --export-ro)
                [ $# -ge 2 ] || die "--export-ro requires an argument"
                exports+=("$2")
                shift 2
                ;;
            --export-rw)
                [ $# -ge 2 ] || die "--export-rw requires an argument"
                exports_rw+=("$2")
                shift 2
                ;;
            --dotfile)
                die "--dotfile has been removed; use --export-ro instead"
                ;;
            --refresh)
                refresh=1
                shift
                ;;
            --deep-check)
                deep_check=1
                shift
                ;;
            --memory)
                [ $# -ge 2 ] || die "--memory requires an argument"
                cli_memory="$2"
                shift 2
                ;;
            --cpus)
                [ $# -ge 2 ] || die "--cpus requires an argument"
                cli_cpus="$2"
                shift 2
                ;;
            --command)
                [ $# -ge 2 ] || die "--command requires an argument"
                command="$2"
                shift 2
                ;;
            --config)
                [ $# -ge 2 ] || die "--config requires an argument"
                cli_config="$2"
                shift 2
                ;;
            --no-network)
                cli_network="0"
                shift
                ;;
            --verbose)
                verbose=1
                shift
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"
                else
                    die "unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Load configuration file (if any). --config overrides the default
    # search; otherwise walk from $PWD upward for .schupfn/config.yml,
    # falling back to $XDG_CONFIG_HOME/schupfn/<name>-config.yml (if the
    # container name is known from the CLI), then default-config.yml.
    # Config values provide defaults; CLI arguments always take precedence.
    local -a _cfg_exports=()
    local -a _cfg_exports_rw=()
    local _cfg_container="" _cfg_command="" _cfg_memory="" _cfg_cpus="" _cfg_network="" _cfg_ssh_key=""
    local config_file
    if [ -n "$cli_config" ]; then
        if [ ! -f "$cli_config" ]; then
            die "config file not found: $cli_config"
        fi
        config_file="$cli_config"
        info "using config: $config_file"
        load_config "$config_file"
    elif config_file=$(find_config_file "$PWD" "$name"); then
        info "using config: $config_file"
        load_config "$config_file"
    fi

    # Container name: CLI wins, then config
    if [ -z "$name" ]; then
        name="${_cfg_container}"
    fi
    if [ -z "$name" ]; then
        die "container name required. See '$PROGNAME enter --help'."
    fi

    validate_container_name "$name"

    # Merge: config exports come first, CLI exports are appended
    exports=("${_cfg_exports[@]}" "${exports[@]}")
    exports_rw=("${_cfg_exports_rw[@]}" "${exports_rw[@]}")

    # Scalars: CLI wins, then config, then built-in default
    memory="${cli_memory:-${_cfg_memory:-4G}}"
    cpus="${cli_cpus:-${_cfg_cpus}}"
    network="${cli_network:-${_cfg_network:-1}}"
    ssh_key="${_cfg_ssh_key}"
    if [ -z "$command" ]; then
        command="${_cfg_command}"
    fi

    check_prerequisites

    # Verify the container exists
    if ! podman container inspect "$name" >/dev/null 2>&1; then
        die "container '$name' does not exist. Create it with 'toolbox create $name'."
    fi

    # Check that the container has required packages installed
    check_container_prerequisites "$name"

    local rootfs_dir="$CACHE_DIR/$name"

    # Check freshness (unless --refresh forces re-export)
    local need_export=0
    if [ "$refresh" = "1" ]; then
        info "forced refresh requested"
        need_export=1
    elif ! check_freshness "$name" "$rootfs_dir" "$deep_check"; then
        need_export=1
    else
        info "rootfs for '$name' is up to date"
    fi

    if [ "$need_export" = "1" ]; then
        export_rootfs "$name" "$rootfs_dir"
    fi

    # Resolve $PWD to its physical path so the 9p mount uses a real
    # directory, not a symlink.  Keep the logical path for virtme_chdir
    # so the user lands in the expected directory.
    local physical_pwd
    if ! physical_pwd="$(realpath "$PWD" 2>/dev/null)" || [ -z "$physical_pwd" ]; then
        die "cannot resolve current directory '$PWD' —" \
            "it may have been deleted or permissions are insufficient."
    fi

    # Refuse to run from $HOME: mounting it via --rwdir (9p) would shadow
    # the --overlay-rwdir on /home, causing everything under $HOME to sit
    # on 9p. Applications that need POSIX file locking or mmap (e.g.
    # SQLite WAL mode) will break.
    # Resolve $HOME to its physical path so the check still works when
    # $HOME itself is a symlink (e.g. /home/user -> /data/users/user).
    local physical_home
    physical_home="$(realpath "$HOME" 2>/dev/null)" || physical_home="$HOME"
    if [ "$physical_pwd" = "$physical_home" ] || [ "$PWD" = "$HOME" ]; then
        die "refusing to start from \$HOME — the 9p mount would shadow" \
            "the overlay on /home and break applications that need" \
            "POSIX file locking. Please cd to a subdirectory first."
    fi

    # Classify each --export-ro / --export-rw path as a directory or file.
    # See classify_export() for details.
    local -a rw_mount_dirs=("$physical_pwd")   # $PWD is always read-write
    local -a ro_mount_dirs=()
    local -a rootfs_symlinks=()
    local -a dotfiles=()

    # If $PWD is (or passes through) a symlink, recreate it in the rootfs
    # so that virtme_chdir and the SSH "cd" both land in the right place.
    if [ "$PWD" != "$physical_pwd" ]; then
        rootfs_symlinks+=("$PWD:$physical_pwd")
    fi

    for path in "${exports[@]}"; do
        classify_export "$path" "ro"
    done
    for path in "${exports_rw[@]}"; do
        classify_export "$path" "rw"
    done

    check_nested_export_conflicts

    # Ensure mount points exist inside the rootfs so virtme-ng can
    # set them up. The rootfs is used with --rw so this is persistent
    # across runs (until re-exported).
    local dir
    for dir in "${rw_mount_dirs[@]}" "${ro_mount_dirs[@]}"; do
        if ! mkdir -p "$rootfs_dir$dir"; then
            die "failed to create mount point '$dir' in rootfs"
        fi
    done

    # Recreate symlinks in the rootfs so the original paths work
    for entry in "${rootfs_symlinks[@]}"; do
        local link_path="${entry%%:*}"
        local target="${entry#*:}"
        local rootfs_link="$rootfs_dir$link_path"
        if [ ! -e "$rootfs_link" ]; then
            mkdir -p "$(dirname "$rootfs_link")"
            ln -s "$target" "$rootfs_link"
        fi
    done

    # Build vng command.
    #
    # Key flags:
    #   --force-9p: use 9p instead of virtiofs for the rootfs. virtiofs
    #     causes hangs with --network due to virtio device conflicts.
    #   --no-virtme-ng-init: use the bash init script which works
    #     reliably with custom rootfs.
    #   --overlay-rwdir: required for --rwdir guest paths when using --root.
    #     We use a common ancestor (/home, /tmp, etc.) rather than / because
    #     overlaying / causes the init to hang.
    local -a vng_cmd=(
        vng --run
        --root "$rootfs_dir"
        --rw
        --force-9p
        --no-virtme-ng-init
        --memory "$memory"
        --name "$name"
    )

    if [ -n "$cpus" ]; then
        vng_cmd+=(--cpus "$cpus")
    fi

    if [ "$network" = "1" ]; then
        vng_cmd+=(--network user)
    fi

    # Mount directories into the VM at their original paths.
    # Each mount needs its parent to be covered by an --overlay-rwdir.
    local -a overlay_dirs=()

    for dir in "${rw_mount_dirs[@]}"; do
        info "exporting directory (rw): $dir"
        vng_cmd+=(--rwdir "$dir=$dir")
        add_overlay "$dir"
    done

    for dir in "${ro_mount_dirs[@]}"; do
        info "exporting directory (ro): $dir"
        vng_cmd+=(--rodir "$dir=$dir")
        add_overlay "$dir"
    done

    # Overlay key system directories so the VM sees correct file ownership.
    # The rootfs is served via 9p with security_model=none, meaning all
    # files appear owned by the host user's UID. This breaks programs
    # that require root ownership (sudo needs setuid-root, rpm/dnf need
    # root-owned database files, PAM checks /etc/sudoers ownership, etc.).
    # An overlayfs on top of 9p restores the original ownership from the
    # container image for everything that is not written to at runtime.
    for sysdir in /usr /var /etc; do
        add_overlay "$sysdir"
    done

    for dir in "${overlay_dirs[@]}"; do
        vng_cmd+=(--overlay-rwdir "$dir")
    done

    # Mount the host's kernel modules into the VM so it can load modules
    # like virtio_net for networking. The VM uses the host kernel but
    # the exported container rootfs doesn't have /lib/modules.
    local kver
    kver=$(uname -r)
    if [ -d "/lib/modules/$kver" ]; then
        vng_cmd+=(--rodir "/lib/modules/$kver=/lib/modules/$kver")
    fi

    vng_cmd+=(--user "$(whoami)")

    # Set working directory inside the VM. We can't use --cwd because it
    # rejects paths outside --root. Pass the kernel arg directly instead —
    # the init script reads virtme_chdir and does cd to it.
    vng_cmd+=(--append "virtme_chdir=$PWD")

    # Tag the VM so processes inside can identify it as schupfn-started.
    # Readable via: grep -o 'schupfn.container=[^ ]*' /proc/cmdline
    vng_cmd+=(--append "schupfn.container=$name")

    # Pick a port for SSH and enable the SSH server inside the VM.
    # Use --ssh-tcp because the VM kernel typically lacks the vsock module.
    local ssh_port
    ssh_port=$(find_free_port)
    vng_cmd+=(--ssh "$ssh_port" --ssh-tcp)

    if [ "$verbose" = "1" ]; then
        vng_cmd+=(--verbose)
    fi

    info "starting VM '$name' (ssh port $ssh_port)..."

    # Run vng in the background. Without --graphics, vng automatically
    # adds -vga none -display none (no GUI window). The serial console
    # is attached to the process's stdio; in verbose mode we show it on
    # stderr, otherwise we redirect everything to /dev/null.
    if [ "$verbose" = "1" ]; then
        "${vng_cmd[@]}" </dev/null >&2 &
    else
        "${vng_cmd[@]}" </dev/null &>/dev/null &
    fi
    VNG_PID=$!
    SESSION_NAME="$name"

    # Ensure we clean up the VM on exit (Ctrl-C, errors, normal exit)
    trap cleanup_vm EXIT

    # Wait for SSH to become available
    wait_for_ssh "$ssh_port"

    # Register this VM session so 'schupfn join' can find it
    write_session "$name" "$VNG_PID" "$ssh_port" "$PWD" "$ssh_key"

    info "VM is up, connecting"

    # Copy exported files into the VM at their original absolute paths.
    # This avoids needing sftp-server in the VM. Symlinks were already
    # resolved to absolute paths during the export classification above.
    # We tar from / with the full path so the directory structure is
    # preserved in the VM (e.g. /home/user/foo/bar/file.txt).
    # Common SSH options used for both file copy and interactive session.
    local -a ssh_opts=(
        -o LogLevel=ERROR
        -F "$HOME/.cache/virtme-ng/.ssh/virtme-ng-ssh.conf"
    )
    if [ -n "$ssh_key" ]; then
        ssh_opts+=(-i "$ssh_key")
    fi

    if [ ${#dotfiles[@]} -gt 0 ]; then
        local user
        user=$(whoami)
        local dest="ssh://virtme-ng:$ssh_port"

        # Strip the leading / so tar creates relative paths, then
        # extract at / in the VM to reconstruct the absolute path.
        local -a tar_paths=()
        for df in "${dotfiles[@]}"; do
            info "copying file: $df"
            tar_paths+=("${df#/}")
        done

        tar -chf - -C / "${tar_paths[@]}" | \
            ssh "${ssh_opts[@]}" -l "$user" "$dest" \
                "tar -xf - -C /" 2>/dev/null \
        || warn "failed to copy exported files"
    fi

    # SSH into the VM. We call ssh directly (rather than vng --ssh-client)
    # because --remote-cmd doesn't allocate a PTY, resulting in no visible
    # prompt. Use the vng SSH config for host key and identity settings,
    # and the "ssh://virtme-ng:<port>" destination so the Host wildcard
    # matches.
    local quoted_pwd
    printf -v quoted_pwd '%q' "$PWD"
    local remote_cmd
    if [ -n "$command" ]; then
        remote_cmd="cd $quoted_pwd && $command"
    else
        remote_cmd="cd $quoted_pwd && exec \$SHELL -l"
    fi

    ssh -t \
        "${ssh_opts[@]}" \
        -l "$(whoami)" \
        "ssh://virtme-ng:$ssh_port" \
        "$remote_cmd"
    local rc=$?

    if [ -n "$command" ]; then
        exit "$rc"
    elif [ $rc -ne 0 ]; then
        warn "SSH session exited with status $rc"
    fi
}

# ── Subcommand: join ────────────────────────────────────────────────────────

cmd_join() {
    local name=""
    local command=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage_join
                exit 0
                ;;
            --command)
                [ $# -ge 2 ] || die "--command requires an argument"
                command="$2"
                shift 2
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"
                else
                    die "unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Find matching sessions
    local -a sessions=()
    mapfile -t sessions < <(list_active_sessions "$name")
    # mapfile with empty input may leave a single empty element; filter it.
    if [ ${#sessions[@]} -eq 1 ] && [ -z "${sessions[0]}" ]; then
        sessions=()
    fi

    if [ ${#sessions[@]} -eq 0 ]; then
        if [ -n "$name" ]; then
            die "no running VM found for '$name'"
        else
            die "no running VMs found"
        fi
        return 1
    fi

    local session_file
    if [ ${#sessions[@]} -eq 1 ]; then
        session_file="${sessions[0]}"
    else
        # Multiple sessions — show them and ask the user to pick one
        echo "Multiple running VMs found:"
        echo ""
        local idx=1
        for sf in "${sessions[@]}"; do
            local sf_name sf_pid sf_port sf_workdir sf_started
            sf_name=$(read_session "$sf" "name")
            sf_pid=$(read_session "$sf" "pid")
            sf_port=$(read_session "$sf" "ssh_port")
            sf_workdir=$(read_session "$sf" "workdir")
            sf_started=$(read_session "$sf" "started_at")
            printf "  %d) %s (pid %s, port %s, dir %s, started %s)\n" \
                "$idx" "$sf_name" "$sf_pid" "$sf_port" "$sf_workdir" "$sf_started"
            idx=$((idx + 1))
        done
        echo ""
        printf "Select VM [1-%d]: " "${#sessions[@]}"
        local choice
        read -r choice
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "${#sessions[@]}" ]; then
            die "invalid selection"
            return 1
        fi
        session_file="${sessions[$((choice - 1))]}"
    fi

    # Read session details
    local ssh_port workdir ssh_key
    ssh_port=$(read_session "$session_file" "ssh_port")
    workdir=$(read_session "$session_file" "workdir")
    ssh_key=$(read_session "$session_file" "ssh_key")

    if ! [[ "$ssh_port" =~ ^[0-9]+$ ]]; then
        die "corrupted session file: invalid ssh_port '$ssh_port'"
        return 1
    fi

    if [ -z "$name" ]; then
        name=$(read_session "$session_file" "name")
    fi

    info "joining VM '$name' (ssh port $ssh_port)..."

    # Build SSH options — same as cmd_enter
    local -a ssh_opts=(
        -o LogLevel=ERROR
        -F "$HOME/.cache/virtme-ng/.ssh/virtme-ng-ssh.conf"
    )
    if [ -n "$ssh_key" ]; then
        ssh_opts+=(-i "$ssh_key")
    fi

    local quoted_workdir
    printf -v quoted_workdir '%q' "$workdir"
    local remote_cmd
    if [ -n "$command" ]; then
        remote_cmd="cd $quoted_workdir && $command"
    else
        remote_cmd="cd $quoted_workdir && exec \$SHELL -l"
    fi

    ssh -t \
        "${ssh_opts[@]}" \
        -l "$(whoami)" \
        "ssh://virtme-ng:$ssh_port" \
        "$remote_cmd"
    local rc=$?

    if [ -n "$command" ]; then
        exit "$rc"
    elif [ $rc -ne 0 ]; then
        warn "SSH session exited with status $rc"
    fi
}

# ── Subcommand: list ────────────────────────────────────────────────────────

cmd_list() {
    if [ ! -d "$CACHE_DIR" ]; then
        echo "No cached rootfs entries."
        return
    fi

    local found=0

    # Clean up stale session files once, then build a per-name VM count
    # in a single pass instead of calling list_active_sessions per rootfs.
    cleanup_stale_sessions

    declare -A _vm_counts=()
    if [ -d "$SESSION_DIR" ]; then
        for session_file in "$SESSION_DIR"/*.session; do
            [ -f "$session_file" ] || continue
            local sname
            sname=$(read_session "$session_file" "name")
            if [ -n "$sname" ]; then
                _vm_counts["$sname"]=$(( ${_vm_counts["$sname"]:-0} + 1 ))
            fi
        done
    fi

    printf "%-20s %-10s %-10s %-10s %s\n" "NAME" "STATUS" "VMs" "SIZE" "EXPORTED"
    printf "%-20s %-10s %-10s %-10s %s\n" "----" "------" "---" "----" "--------"

    for rootfs_dir in "$CACHE_DIR"/*/; do
        [ -d "$rootfs_dir" ] || continue

        local name
        name=$(basename "$rootfs_dir")
        found=1

        # Get size
        local size
        size=$(du -sh "$rootfs_dir" 2>/dev/null | cut -f1)

        # Get export date
        local exported_at
        exported_at=$(read_meta "$rootfs_dir" "exported_at")
        if [ -z "$exported_at" ]; then
            exported_at="unknown"
        fi

        # Check freshness
        local status="unknown"
        if podman container inspect "$name" >/dev/null 2>&1; then
            if check_freshness "$name" "$rootfs_dir" "0" >/dev/null 2>&1; then
                status="fresh"
            else
                status="stale"
            fi
        else
            status="orphaned"
        fi

        # Look up running VM count from the pre-built map
        local vm_count="${_vm_counts["$name"]:-0}"
        local vm_display
        if [ "$vm_count" -gt 0 ]; then
            vm_display="$vm_count running"
        else
            vm_display="-"
        fi

        printf "%-20s %-10s %-10s %-10s %s\n" "$name" "$status" "$vm_display" "$size" "$exported_at"
    done

    if [ "$found" = "0" ]; then
        echo "No cached rootfs entries."
    fi
}

# ── Subcommand: clean ──────────────────────────────────────────────────────

cmd_clean() {
    local name="${1:-}"

    if [ -n "$name" ]; then
        validate_container_name "$name"
        local rootfs_dir="$CACHE_DIR/$name"
        if [ ! -d "$rootfs_dir" ]; then
            die "no cached rootfs for '$name'"
        fi

        info "removing cached rootfs for '$name'..."
        podman unshare rm -rf "$rootfs_dir"
        if [ $? -ne 0 ]; then
            die "failed to remove '$rootfs_dir'"
        fi
        info "done"
        return
    fi

    # Clean all
    if [ ! -d "$CACHE_DIR" ]; then
        echo "Nothing to clean."
        return
    fi

    local count
    count=$(find "$CACHE_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)

    if [ "$count" = "0" ]; then
        echo "Nothing to clean."
        return
    fi

    printf "%-20s %s\n" "NAME" "SIZE"
    printf "%-20s %s\n" "----" "----"
    for rootfs_dir in "$CACHE_DIR"/*/; do
        [ -d "$rootfs_dir" ] || continue
        local entry_name entry_size
        entry_name=$(basename "$rootfs_dir")
        entry_size=$(du -sh "$rootfs_dir" 2>/dev/null | cut -f1)
        printf "%-20s %s\n" "$entry_name" "$entry_size"
    done
    echo ""
    printf "Remove all %d cached rootfs entries? [y/N] " "$count"
    read -r answer
    case "$answer" in
        y|Y|yes|YES)
            podman unshare rm -rf "$CACHE_DIR"
            if [ $? -ne 0 ]; then
                die "failed to remove '$CACHE_DIR'"
            fi
            info "cleaned $count entries"
            ;;
        *)
            info "aborted"
            ;;
    esac
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    local command="$1"
    shift

    case "$command" in
        enter)
            cmd_enter "$@"
            ;;
        join)
            cmd_join "$@"
            ;;
        list|ls)
            cmd_list "$@"
            ;;
        clean)
            cmd_clean "$@"
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
        --version)
            echo "$PROGNAME $VERSION"
            exit 0
            ;;
        *)
            die "unknown command: $command. See '$PROGNAME --help'."
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
